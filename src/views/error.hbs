<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <!-- Nhúng trực tiếp Bootstrap cho trang lỗi chạy độc lập siêu nhanh -->
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons (tùy chọn) -->
    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body class="bg-light d-flex align-items-center min-vh-100">
    <div class="container py-5">
        <div class="row justify-content-center w-100 m-0">
            <div class="col-md-8 col-lg-6 text-center">
                <div class="mb-4">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 5rem;"></i>
                </div>
                <h1 class="display-1 fw-bold text-dark mb-2">{{statusCode}}</h1>
                <h3 class="h4 text-secondary mb-3">Rất tiếc! Đã có lỗi xảy ra</h3>
                <div class="alert alert-danger shadow-sm border-0 mb-4 text-start" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <strong>Thông báo:</strong> {{message}}
                </div>
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mb-5">
                    <a href="/" class="btn btn-primary btn-lg px-4 gap-3 shadow text-decoration-none">
                        <i class="bi bi-house-door-fill me-2"></i>Quay lại Trang chủ
                    </a>
                    <button onclick="window.history.back()" class="btn btn-outline-secondary btn-lg px-4">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại trang trước
                    </button>
                </div>
                {{#if stack}}
                    <div class="card text-start border-warning shadow-sm">
                        <div class="card-header bg-warning text-dark fw-bold d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-code-slash me-2"></i>Developer Stack Trace</span>
                            <span class="badge bg-dark">development mode</span>
                        </div>
                        <div class="card-body bg-dark text-warning p-0">
                            <pre class="m-0 p-3" style="font-size: 0.85rem; max-height: 350px; overflow-y: auto; font-family: 'Courier New', Courier, monospace; white-space: pre-wrap; word-break: break-all;">{{stack}}</pre>
                        </div>
                    </div>
                {{/if}}
                <p class="text-muted small mt-4">&copy; Badminton Shop - Hệ thống quản lý và bán hàng</p>
            </div>
        </div>
    </div>
</body>
</html>
