<div class="container-fluid px-4 px-md-5 py-4">
    
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-sky">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/products" class="text-decoration-none text-sky">Sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{product.name}}</li>
        </ol>
    </nav>

    <div class="row mb-5">
        <div class="col-12 col-md-5 col-lg-4 mb-4 mb-md-0">
            <div class="border rounded-3 p-2 mb-3 text-center bg-white">
                <img id="mainProductImage" src="{{product.images.[0].image_url}}" class="img-fluid" alt="{{product.name}}" style="max-height: 400px; object-fit: contain;">
            </div>
            
            <div class="d-flex gap-2 overflow-auto gallery-thumbnails">
                {{#each product.images}}
                <div class="border rounded-2 p-1 bg-white cursor-pointer thumbnail-item" onclick="changeMainImage('{{this.image_url}}')" style="width: 80px; height: 80px; flex-shrink: 0; cursor: pointer;">
                    <img src="{{this.image_url}}" class="img-fluid w-100 h-100" style="object-fit: contain;" alt="Thumbnail">
                </div>
                {{/each}}
            </div>
        </div>

        <div class="col-12 col-md-7 col-lg-8 ps-md-4">
            <span class="badge bg-dark mb-2 px-3 py-2 text-uppercase">{{product.brand_name}}</span>
            
            <h2 class="fw-bold mb-3">{{product.name}}</h2>
            <h3 class="text-danger fw-bold mb-4" style="color: #f97316 !important;">
                {{product.formattedDefaultPrice}}
            </h3>

            <div class="mb-4">
                <p class="fw-bold mb-2">Chọn phiên bản:</p>
                <div class="d-flex flex-wrap gap-2">
                    {{#each product.variants}}
                        <input type="radio" class="btn-check" name="variantOptions" id="variant_{{this.variant_id}}" autocomplete="off" {{#if @first}}checked{{/if}}>
                        <label class="btn btn-outline-secondary" for="variant_{{this.variant_id}}">
                            {{this.variant_name}} </label>
                    {{/each}}
                </div>
            </div>

            <div class="d-flex gap-3 mb-4">
                <div class="input-group" style="width: 130px;">
                    <button class="btn btn-outline-secondary" type="button" id="btn-minus">-</button>
                    <input type="text" class="form-control text-center fw-bold" value="1" id="input-quantity">
                    <button class="btn btn-outline-secondary" type="button" id="btn-plus">+</button>
                </div>
                <button class="btn btn-lg btn-danger px-5 fw-bold" style="background-color: #f97316; border-color: #f97316;">
                    <i class="bi bi-cart-plus me-2"></i> THÊM VÀO GIỎ
                </button>
            </div>
            
            <div class="bg-light p-3 rounded-3 mt-4">
                <p class="mb-1"><i class="bi bi-check-circle-fill text-success me-2"></i>Cam kết hàng chính hãng 100%</p>
                <p class="mb-1"><i class="bi bi-shield-check text-sky me-2"></i>Bảo hành 90 ngày (Lỗi nhà sản xuất)</p>
                <p class="mb-0"><i class="bi bi-box-seam text-warning me-2"></i>Tặng kèm lưới và quấn cán</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-lg-8">
            <h4 class="border-bottom pb-2 mb-4 fw-bold">Thông tin chi tiết</h4>
            <div class="product-description" style="line-height: 1.8;">
                {{{product.description}}} 
            </div>
        </div>
    </div>
</div>

<script>
    function changeMainImage(imageUrl) {
        document.getElementById('mainProductImage').src = imageUrl;
    }
</script>