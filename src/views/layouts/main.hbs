<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="/css/style.css">

    <style>
        /* ================= TÙY CHỈNH MÀU SẮC ================= */
        :root {
            --primary-sky: #0ea5e9;       /* Xanh da trời chủ đạo */
            --primary-sky-dark: #0284c7;  /* Xanh đậm khi hover */
            --text-dark: #333333;
        }
        
        .text-sky { color: var(--primary-sky) !important; }
        .bg-sky { background-color: var(--primary-sky) !important; }

        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            font-family: Arial, sans-serif;
        }

        /* ================= TOP HEADER (Logo, Search, Icons) ================= */
        .top-header {
            font-size: 14px;
        }
        
        /* Cụm icon góc phải */
        .header-action-item {
            text-decoration: none;
            color: var(--text-dark);
            display: flex;
            flex-direction: column;
            align-items: center;
            font-size: 12px;
            font-weight: 500;
            transition: color 0.2s;
        }
        .header-action-item:hover {
            color: var(--primary-sky);
        }
        .header-action-item i {
            font-size: 22px;
            color: var(--primary-sky);
            margin-bottom: 2px;
            position: relative;
        }
        
        /* Chấm số lượng trên giỏ hàng */
        .cart-badge {
            position: absolute;
            top: -4px;
            right: -8px;
            background-color: #f97316; /* Màu cam nổi bật giống web gốc */
            color: white;
            font-size: 10px;
            font-family: sans-serif;
            padding: 2px 5px;
            border-radius: 50%;
            font-weight: bold;
        }

        /* Khung tìm kiếm */
        .search-box .form-control {
            border-right: none;
            background-color: #f8f9fa;
        }
        .search-box .form-control:focus {
            border-color: #ced4da;
            box-shadow: none;
            background-color: white;
        }
        .search-box .btn-search {
            background-color: #f8f9fa;
            border: 1px solid #ced4da;
            border-left: none;
            color: var(--primary-sky);
        }
        .search-box .form-control:focus + .btn-search {
            background-color: white;
        }

        /* ================= MAIN NAVBAR ================= */
        .main-nav {
            background-color: var(--primary-sky);
        }
        
        /* Cho phép menu cuộn ngang trên màn hình nhỏ */
        .main-nav-wrapper {
            display: flex;
            overflow-x: auto;
            white-space: nowrap;
            /* Ẩn scrollbar nhưng vẫn vuốt được */
            -ms-overflow-style: none;  
            scrollbar-width: none;  
        }
        .main-nav-wrapper::-webkit-scrollbar { 
            display: none; 
        }

        .main-nav-wrapper .nav-link {
            color: white !important;
            font-weight: bold;
            font-size: 14px;
            text-transform: uppercase;
            padding: 15px 20px !important;
            transition: background-color 0.2s;
        }
        .main-nav-wrapper .nav-link:hover {
            background-color: var(--primary-sky-dark);
        }
        .icon-dropdown {
            font-size: 10px;
            vertical-align: middle;
            margin-left: 2px;
        }

        /* ================= DROPDOWN HOVER MENU ================= */
        .nav-item-dropdown {
            position: relative;
            display: inline-block;
        }

        .nav-item-dropdown .custom-dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            min-width: 220px;
            background-color: white;
            box-shadow: 0 8px 16px rgba(0,0,0,0.1);
            border-top: 3px solid var(--primary-sky);
            z-index: 1000;
            padding: 0;
            margin: 0;
            border-radius: 0 0 5px 5px;
            list-style: none;
        }

        /* Hiển thị menu khi hover trên Desktop */
        @media (min-width: 992px) {
            .nav-item-dropdown:hover .custom-dropdown-menu {
                display: block;
            }
            /* Ghi đè overflow để menu không bị cắt lẹm bên trong wrapper */
            .main-nav-wrapper {
                overflow: visible !important;
            }
        }

        .custom-dropdown-item {
            display: block;
            padding: 12px 20px;
            color: var(--text-dark);
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            transition: all 0.2s;
            border-bottom: 1px solid #f1f5f9;
            white-space: normal; /* Cho phép chữ tự xuống dòng nếu quá dài */
        }

        .custom-dropdown-item:last-child {
            border-bottom: none;
        }

        .custom-dropdown-item:hover {
            background-color: #f8f9fa;
            color: var(--primary-sky);
            padding-left: 25px; /* Hiệu ứng thụt lề nhẹ khi hover */
        }
    </style>
</head>

<body>

    <header class="top-header bg-white py-3 border-bottom">
        <div class="container-fluid px-4 px-md-5">
            <div class="row align-items-center">
                
                <div class="col-12 col-lg-2 text-center text-lg-start mb-3 mb-lg-0">
                    <a href="/" class="text-decoration-none">
                        <h2 class="m-0 fw-bold text-dark" style="letter-spacing: -1px;">LOGO<span class="text-sky">TEST</span></h2>
                    </a>
                </div>

                <div class="col-12 col-lg-4 d-none d-lg-flex align-items-center gap-4">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-telephone-fill text-sky fs-5"></i>
                        <span class="fw-bold" style="font-size: 13px;">HOTLINE: <span class="text-sky">0394455801</span></span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-geo-alt-fill text-sky fs-5"></i>
                        <span class="fw-bold" style="font-size: 13px;">HỆ THỐNG CỬA HÀNG</span>
                    </div>
                </div>

                <div class="col-8 col-lg-3">
                    <div class="input-group search-box">
                        <input type="text" class="form-control" placeholder="Tìm sản phẩm...">
                        <button class="btn btn-search" type="button"><i class="bi bi-search"></i></button>
                    </div>
                </div>

                <div class="col-4 col-lg-3 d-flex justify-content-end gap-3 gap-md-4">
                    {{#if user}}
                    <div class="dropdown">
                        <a class="header-action-item dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle"></i>
                            <span>{{user.fullName}}</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li><a class="dropdown-item" href="/account"><i class="bi bi-person me-2"></i>Tài khoản</a></li>
                            <li><a class="dropdown-item" href="/orders"><i class="bi bi-box me-2"></i>Đơn hàng</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><form action="/logout" method="POST" class="d-inline"><button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button></form></li>
                        </ul>
                    </div>
                    {{else}}
                    <a href="/login" class="header-action-item">
                        <i class="bi bi-person"></i>
                        <span>ĐĂNG NHẬP</span>
                    </a>
                    {{/if}}
                    <a href="/cart" class="header-action-item">
                        <i class="bi bi-cart3">
                            <span class="cart-badge">0</span>
                        </i>
                        <span>GIỎ HÀNG</span>
                    </a>
                </div>

            </div>
        </div>
    </header>

    <nav class="main-nav">
        <div class="container-fluid px-4 px-md-5">
            <div class="main-nav-wrapper">
                <a class="nav-link" href="/">TRANG CHỦ</a>
                <div class="nav-item-dropdown">
                    <a class="nav-link" href="/products">SẢN PHẨM <i class="bi bi-chevron-down icon-dropdown"></i></a>
    
                    <ul class="custom-dropdown-menu">
                        <li><a class="custom-dropdown-item" href="/category/vot-cau-long"><i class="bi bi-caret-right-fill text-sky" style="font-size: 10px; margin-right: 5px;"></i> Vợt cầu lông</a></li>
                        <li><a class="custom-dropdown-item" href="/category/giay-cau-long"><i class="bi bi-caret-right-fill text-sky" style="font-size: 10px; margin-right: 5px;"></i> Giày cầu lông</a></li>
                        <li><a class="custom-dropdown-item" href="/category/ao-cau-long"><i class="bi bi-caret-right-fill text-sky" style="font-size: 10px; margin-right: 5px;"></i> Áo cầu lông</a></li>
                        <li><a class="custom-dropdown-item" href="/category/quan-cau-long"><i class="bi bi-caret-right-fill text-sky" style="font-size: 10px; margin-right: 5px;"></i> Quần cầu lông</a></li>
                        <li><a class="custom-dropdown-item" href="/category/phu-kien"><i class="bi bi-caret-right-fill text-sky" style="font-size: 10px; margin-right: 5px;"></i> Phụ kiện & Khác</a></li>
                    </ul>
            </div>
                <a class="nav-link" href="/sale">SALE OFF</a>
                <a class="nav-link" href="/news">TIN TỨC</a>
                <a class="nav-link" href="/careers">TUYỂN DỤNG</a>
                <a class="nav-link" href="/franchise">CHÍNH SÁCH NHƯỢNG QUYỀN</a>
                <a class="nav-link" href="/guides">HƯỚNG DẪN <i class="bi bi-chevron-down icon-dropdown"></i></a>
                <a class="nav-link" href="/about">GIỚI THIỆU</a>
                <a class="nav-link" href="/contact">LIÊN HỆ</a>
            </div>
        </div>
    </nav>

    <main class="container-fluid px-4 px-md-5 my-4 flex-grow-1">
        {{{body}}}
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-auto">
        <div class="container">
            © 2026 My Website
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    

</body>
</html>